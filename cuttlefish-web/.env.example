# Cuttlefish Web Dashboard Environment Variables
# Copy this file to .env.local and fill in your values

# API Configuration
NUXT_PUBLIC_API_BASE=http://localhost:8080
NUXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NUXT_PUBLIC_SITE_URL=https://app.cuttlefish.dev

# Server-side Configuration (used during build and runtime)
NUXT_API_BASE=http://localhost:8080
NUXT_WS_URL=ws://localhost:8080/ws

# Authentication
# NUXT_PUBLIC_API_KEY=your-api-key-here

# Feature Flags
NUXT_PUBLIC_ENABLE_TEMPLATES=true
NUXT_PUBLIC_ENABLE_LOGS=true
NUXT_PUBLIC_ENABLE_SETTINGS=true

# Analytics (optional)
# NUXT_PUBLIC_ANALYTICS_ID=
